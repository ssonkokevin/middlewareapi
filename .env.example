# ── NIRA PRODUCTION ───────────────────────────────────────────────────────────
NIRA_PROD_URL=http://<nira-host>:<port>/path?wsdl
NIRA_PROD_USERNAME=your_nira_username
NIRA_PROD_PASSWORD=your_nira_password
NIRA_PROD_ALLOWED_IP=10.20.20.1

# ── NIRA TEST ─────────────────────────────────────────────────────────────────
NIRA_TEST_URL=http://<nira-host>:<port>/path?wsdl
NIRA_TEST_USERNAME=your_nira_username
NIRA_TEST_PASSWORD=your_nira_password
NIRA_TEST_ALLOWED_IP=127.0.0.1

# ── REFUGEE PRODUCTION ───────────────────────────────────────────────────────
REFUGEE_PROD_VALIDATE_URL=http://<refugee-host>/refugees/api/validate/
REFUGEE_PROD_LOGIN_URL=http://<refugee-host>/refugees/api/login/
REFUGEE_PROD_USERNAME=your_refugee_username
REFUGEE_PROD_PASSWORD=your_refugee_password
REFUGEE_PROD_ALLOWED_IP=192.168.168.10

# ── REFUGEE TEST ──────────────────────────────────────────────────────────────
REFUGEE_TEST_VALIDATE_URL=http://<refugee-host>/refugees/api/validate/
REFUGEE_TEST_LOGIN_URL=http://<refugee-host>/refugees/api/login/
REFUGEE_TEST_USERNAME=your_refugee_username
REFUGEE_TEST_PASSWORD=your_refugee_password
REFUGEE_TEST_ALLOWED_IP=127.0.0.1

# ── SHARED ────────────────────────────────────────────────────────────────────
NIRA_CERT_PATH=wwwroot/certificates/niragoug.crt
TIMEOUT=60
DEBUG=false

# ── CLIENT CREDENTIALS ─────────────────────────────────────────────────────────
# Generated via POST /admin/clients/generate — add each client here and restart
CLIENT_<NAME>_ID=your_client_id
CLIENT_<NAME>_SECRET=your_client_secret

# ── REDIS ───────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ADMIN ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET_KEY=your_strong_admin_secret_key
